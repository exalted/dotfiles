#!/usr/bin/env ruby
require 'pathname'
require_relative '../src/common'

Dir.glob("#{__dir__}/../src/steps/*")
   .map { |file| Pathname.new(file).sub_ext '' }
   .each { |file| require_relative file }

_resolve_profile
_keep_sudo_alive

# These are various system-wide installers, homebrew being the mother of all:
install_homebrew
_shadow_brew_with_pty
install_mas

# … then comes the real deal:
setup
upgrade_everything
install_everything
wrapup
cleanup

# TODO: new/changed commands, aliases, functions, etc. aren't available in the
# current shell session until it's restarted or ~/.bashrc is re-sourced.
#
# Problem: this script runs as a subprocess of the invoking shell, and a child
# process cannot modify its parent's environment/functions/aliases — not even
# by shelling out to `source ~/.bashrc` here, since that would only affect a
# throwaway grandchild subshell, not the shell that ran `dotfiles`.
#
# Solution: change how `dotfiles` is invoked — replace the plain PATH
# executable with a shell function (e.g. in bash/commands.bashrc) that runs
# this script and then sources ~/.bashrc itself, in the same process:
#   dotfiles() { command ruby "$DOTFILES_ROOT/bin/dotfiles" "$@" && source ~/.bashrc; }

ohai "Okey dokey… see you next time!"
